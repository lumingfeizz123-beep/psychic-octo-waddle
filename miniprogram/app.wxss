/* 全局样式重置 */
page {
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  background-color: #f5f5f5;
  color: #333;
}
view, text, button, input, textarea {
  box-sizing: border-box;
}
/* 通用容器 */
.container {
  padding: 15rpx;
  width: 100%;
}
/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}
/* 按钮通用样式 */
.btn {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  padding: 15rpx 20rpx;
  text-align: center;
  font-size: 32rpx;
  margin: 10rpx 0;
}
.btn:active {
  background-color: #388E3C;
}
.btn-gray {
  background-color: #ccc;
}
.btn-gray:active {
  background-color: #999;
}
/* 加载状态 */
.loading {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 28rpx;
}
/* 空数据提示 */
.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}
/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}
/* 副标题 */
.subtitle {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}
/* 文本提示 */
.tip {
  font-size: 26rpx;
  color: #f44336;
  margin: 10rpx 0;
}
/* 输入框通用样式 */
.input {
  border: 1px solid #eee;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
  width: 100%;
}