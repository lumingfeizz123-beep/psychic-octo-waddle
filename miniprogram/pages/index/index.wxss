/* 公告栏 */
.notice-bar {
  padding: 15rpx;
  background-color: #ffebee;
  border-left: 5rpx solid #f44336;
  margin-bottom: 20rpx;
}
/* 分类入口 */
.category-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.category-item {
  width: 30%;
  text-align: center;
  margin-bottom: 20rpx;
}
.category-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 10rpx;
}
/* 排序栏 */
.sort-bar {
  display: flex;
  justify-content: center;
  padding: 10rpx;
  margin-bottom: 20rpx;
}
.sort-btn {
  width: 120rpx;
  margin: 0 10rpx;
  background-color: #eee;
  color: #666;
}
.sort-btn.active {
  background-color: #4CAF50;
  color: #fff;
}
/* 任务项 */
.task-item {
  padding: 20rpx 0;
  border-bottom: 1px solid #eee;
  position: relative;
}
.task-item:last-child {
  border-bottom: none;
}
.task-top-tag {
  position: absolute;
  top: 20rpx;
  right: 0;
  background-color: #f44336;
  color: #fff;
  font-size: 24rpx;
  padding: 5rpx 10rpx;
  border-radius: 4rpx;
}
.task-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.task-meta {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
}