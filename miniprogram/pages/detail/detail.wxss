/* 基础信息 */
.basic-info {
  margin-bottom: 20rpx;
}
.meta-row {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}
/* 操作步骤 */
.steps {
  margin-bottom: 20rpx;
}
.step-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 15rpx;
}
.step-num {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  margin-right: 15rpx;
  flex-shrink: 0;
}
.step-text {
  font-size: 28rpx;
  line-height: 40rpx;
}
/* 关键信息 */
.key-info {
  margin-bottom: 20rpx;
}
/* 互动按钮 */
.action-bar {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}
.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: none;
  padding: 0;
}
.action-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 5rpx;
}
/* 评论区 */
.comments {
  margin-bottom: 20rpx;
}
.comment-item {
  padding: 15rpx 0;
  border-bottom: 1px solid #eee;
}
.comment-item:last-child {
  border-bottom: none;
}
.comment-content {
  font-size: 28rpx;
  margin-bottom: 5rpx;
}
.comment-time {
  font-size: 24rpx;
  color: #999;
}
.comment-input {
  margin-top: 20rpx;
}