<view class="container">
  <!-- 分类列表 -->
  <view class="card category-list">
    <view 
      class="category-item {{selectedId === item.id ? 'active' : ''}}"
      wx:for="{{categories}}" 
      wx:key="id"
      bindtap="selectCategory"
      data-id="{{item.id}}"
    >
      <image src="{{item.icon}}" class="category-icon"></image>
      <text>{{item.name}}</text>
    </view>
  </view>

  <!-- 分类下的任务列表 -->
  <view class="card task-list">
    <text class="title">{{selectedName}} - 相关信息</text>
    <view wx:if="{{loading}}">
      <text class="loading">加载中...</text>
    </view>
    <view wx:else if="{{filteredTasks.length === 0}}">
      <text class="empty">暂无{{selectedName}}相关信息</text>
    </view>
    <view wx:else>
      <view 
        class="task-item" 
        wx:for="{{filteredTasks}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <view class="task-info">
          <text class="task-title">{{item.title}}</text>
          <view class="task-meta">
            <text>收益：{{item.income}}</text>
            <text>难度：{{item.difficulty}}</text>
            <text>{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>